{
  "name": "housing-insights",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "start": "bun run --cwd apps/api start",
    "cli": "bun run --cwd apps/api cli",
    "daemon": "bun run --cwd apps/api daemon",
    "migrate": "bun run --cwd apps/api migrate",
    "test": "bun run --cwd apps/api test",
    "test:web": "bun run --cwd apps/web test",
    "test:all": "bun run test && bun run test:web",
    "build:web": "bun run --cwd apps/web build",
    "typecheck:web": "bun run --cwd apps/web typecheck"
  }
}
