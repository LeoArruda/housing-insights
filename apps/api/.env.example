# Copy to .env and adjust. Paths are relative to process cwd (usually repo root or apps/api).

DATABASE_PATH=./data/platform.sqlite

# HTTP server (read API)
PORT=3000
HOST=127.0.0.1

# Outbound HTTP
HTTP_TIMEOUT_MS=30000
HTTP_MAX_RETRIES=3
HTTP_USER_AGENT=housing-insights/0.1 (contact: dev@local)

# RSS feed URLs (public)
STATCAN_RSS_URL=https://www.statcan.gc.ca/eng/rss/sc-Bull
BOC_RSS_URL=https://www.bankofcanada.ca/feed/

# BoC Valet (public JSON)
BOC_VALET_URL=https://www.bankofcanada.ca/valet/observations/FXUSDCAD/json?recent=1

# StatCan WDS — catalog (getAllCubesListLite JSON file or live GET)
# STATCAN_CATALOG_PATH=../../allstatscan.json
STATCAN_CATALOG_FROM_API=false
STATCAN_KEYWORDS_PATH=
STATCAN_INGEST_MODE=explicit
STATCAN_PRODUCT_IDS=
STATCAN_MAX_CUBES_PER_JOB=50
STATCAN_MIN_KEYWORD_SCORE=1
STATCAN_LATEST_N=3
STATCAN_DEFAULT_DATA_COORDINATE=
STATCAN_DATA_VECTOR_IDS=
STATCAN_REQUEST_DELAY_MS=200
# Max raw rows per run of job `statcan-wds-data-normalize`
STATCAN_WDS_NORMALIZE_BATCH_LIMIT=500

# Operational logs (SQLite `operation_logs` + optional JSONL mirror)
# OPERATIONS_LOG_JSONL_PATH=./data/operations.jsonl
OPERATIONS_LOG_RETENTION_DAYS=30

# Daemon cron expressions (see croner / standard 5-field cron)
DAEMON_STATCAN_RSS_CRON=0 * * * *
DAEMON_BOC_RSS_CRON=15 * * * *
DAEMON_STATCAN_CATALOG_CRON=0 2 * * 0
DAEMON_STATCAN_WDS_METADATA_CRON=0 6 * * *
DAEMON_STATCAN_WDS_DATA_CRON=30 6 * * *
# Per-product StatCan schedules (see statcan_product_schedules table)
DAEMON_STATCAN_SCHEDULE_TICK_CRON=*/5 * * * *
# Optional: global subject subscriptions × changed cubes (`statcan-subject-changed-ingest`)
# DAEMON_STATCAN_SUBJECT_CHANGED_CRON=15 * * * *
DAEMON_BOC_VALET_CRON=30 6 * * *
# Optional: normalize `statcan-wds-data` raws into `statcan_wds_data_*` tables (omit to run via CLI only)
# DAEMON_STATCAN_WDS_DATA_NORMALIZE_CRON=45 6 * * *
# Optional: prune `operation_logs` older than OPERATIONS_LOG_RETENTION_DAYS (e.g. weekly)
# DAEMON_OPERATIONS_LOG_PRUNE_CRON=0 4 * * 0

# Web ops console / SPA: optional Bearer keys (if either is set, all routes except /health require Authorization)
# DASHBOARD_OPERATOR_KEY=
# DASHBOARD_VIEWER_KEY=
# Dev CORS for Vite (e.g. http://localhost:5173)
# CORS_ALLOW_ORIGIN=
